    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentui/core": "0.2.2",
    "@opentui/solid": "0.2.2",
    "@tsconfig/node22": "22.0.2",
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "@typescript/native-preview": "7.0.0-dev.20251207.1"
  }
