{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@opencode-ai/plugin",
  "version": "1.14.33",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsc"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tool": {
      "import": "./dist/tool.js",
      "types": "./dist/tool.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@opencode-ai/sdk": "1.14.33",
    "effect": "4.0.0-beta.57",
    "zod": "4.1.8"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.2.2",
    "@opentui/solid": ">=0.2.2"
  },
