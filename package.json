{
  "name": "@zbluex/opencode-background-panel",
  "version": "0.2.5",
  "type": "module",
  "description": "OpenCode TUI plugin showing real-time background task list",
  "main": "dist/tui/index.js",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/tui/index.d.ts",
      "import": "./dist/tui/index.js"
    },
    "./tui": {
      "types": "./dist/tui/index.d.ts",
      "import": "./dist/tui/index.js"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "scripts": {
    "build": "bunx --yes shx mkdir -p dist/tui && bun build src/tui/index.tsx --outdir=dist/tui --target=bun --external solid-js --external @opentui/solid",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.0",
    "solid-js": ">=1.8.0",
    "@opentui/solid": ">=0.1.95"
  },
  "dependencies": {},
  "devDependencies": {
    "@opencode-ai/plugin": ">=1.2.0",
    "@opentui/solid": ">=0.1.95",
    "shx": "^0.4.0",
    "solid-js": ">=1.8.0"
  }
}
