{
  "name": "@zbluex/opencode-background-panel",
  "version": "0.2.6",
  "type": "module",
  "description": "OpenCode TUI plugin showing real-time background task list",
  "main": "src/tui/index.tsx",
  "types": "src/tui/index.tsx",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/tui/index.tsx",
      "import": "./src/tui/index.tsx"
    },
    "./tui": {
      "types": "./src/tui/index.tsx",
      "import": "./src/tui/index.tsx"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "scripts": {
    "build": "bunx --yes shx mkdir -p dist/tui && bun build src/tui/index.tsx --outdir=dist/tui --target=bun --external solid-js",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.0",
    "solid-js": ">=1.8.0",
    "@opentui/solid": ">=0.1.95"
  },
  "dependencies": {},
  "devDependencies": {
    "@opencode-ai/plugin": ">=1.2.0",
    "@opentui/solid": ">=0.1.95",
    "shx": "^0.4.0",
    "solid-js": ">=1.8.0"
  }
}
