{
  "name": "@zbluex/opencode-background-panel",
  "version": "0.2.17",
  "type": "module",
  "description": "OpenCode TUI plugin showing real-time background task list",
  "homepage": "https://github.com/zbluex/opencode-background-panel",
"main": "dist/index.js",
  "files": [
    "dist",
    "src/tui",
    "src/shared",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./src/tui/index.tsx",
      "import": "./src/tui/index.tsx"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile=dist/index.js --target bun --format esm --external @opencode-ai/plugin",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@opencode-ai/plugin": ">=1.2.0",
    "@opentui/solid": ">=0.1.95",
    "shx": "^0.4.0",
    "solid-js": ">=1.8.0"
  }
}
